root = true

[*]
insert_final_newline = true
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
trim_trailing_whitespace = true
charset = utf-8
max_line_length = 120

[*.{hlsl,rc,sln,vcxproj,vcxproj.filters}]
end_of_line = crlf

[*.{sln,vcxproj,vcxproj.filters}]
charset = utf-8-bom
